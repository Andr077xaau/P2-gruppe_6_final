# ── Maven ─────────────────────────────────────────────────────────────────────
# Compiled output — rebuilt automatically from source
target/

# ── Vaadin ────────────────────────────────────────────────────────────────────
# Node.js and npm packages downloaded by Vaadin internally (can be 100MB+)
node_modules/
node/
.pnpm-store/

# Files auto-generated by Vaadin on startup — not hand-written code
**/frontend/generated/
**/src/main/bundles/
webpack.config.js
vite.config.ts
pnpmfile.cjs
.npmrc

# ── Eclipse IDE ───────────────────────────────────────────────────────────────
# Machine-specific IDE config — breaks other people's setups if committed
.project
.classpath
.settings/

# ── IntelliJ IDEA ─────────────────────────────────────────────────────────────
.idea/
*.iml

# ── Compiled Java ─────────────────────────────────────────────────────────────
# .class files generated by IDEs directly into the src/ folder (not via Maven)
**/*.class

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite database file — auto-created on first run, should not be in source control
*.db

# ── JVM crash logs ────────────────────────────────────────────────────────────
hs_err_pid*.log
replay_pid*.log

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
